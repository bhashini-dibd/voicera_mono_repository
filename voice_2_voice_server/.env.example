# ============================================
# Voice Server Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# === Vobiz Telephony API ===
VOBIZ_AUTH_ID=your-vobiz-auth-id
VOBIZ_AUTH_TOKEN=your-vobiz-auth-token
VOBIZ_API_BASE=https://api.vobiz.in/v1
VOBIZ_CALLER_ID=+91XXXXXXXXXX

# === Telnyx Telephony (alternative to Vobiz) ===
# Create credentials at https://portal.telnyx.com/
# TELNYX_API_KEY: V2 API key (starts with "KEY")
# TELNYX_CONNECTION_ID: the Call Control App ID your number is assigned to
# TELNYX_CALLER_ID: E.164 number provisioned on Telnyx
TELNYX_API_KEY=your_telnyx_api_key_here
TELNYX_CONNECTION_ID=your_telnyx_connection_id_here
TELNYX_CALLER_ID=+1XXXXXXXXXX

# === Server URLs ===
# Public URL where this server is accessible (for Vobiz callbacks)
JOHNAIC_SERVER_URL=https://your-server-domain.com
# WebSocket URL prefix for audio streaming
JOHNAIC_WEBSOCKET_URL=wss://your-server-domain.com

# === Backend API ===
VOICERA_BACKEND_URL=http://localhost:8000
# Internal API key for secure service-to-service communication
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_KEY=your-internal-api-key-here

# === MinIO Storage ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# === Bhashini STT API ===
BHASHINI_API_KEY=your-bhashini-api-key
BHASHINI_SOCKET_URL=your-bhasini-wss-url

# === External TTS/STT Services (if using local AI4Bharat servers) ===
AI4BHARAT_STT_URL=http://localhost:8001
AI4BHARAT_TTS_URL=http://localhost:8002

# === Sarvam LLM (NVIDIA NVCF hosted sarvamai/sarvam-30b) ===
# API key for the NVIDIA Cloud Functions endpoint
SARVAM_LLM_API_KEY=nvapi-your-nvidia-api-key-here
# Inference endpoint URL (defaults to the NVIDIA NVCF endpoint below if not set)
SARVAM_LLM_ENDPOINT=https://e75f29cc-857c-4a05-ac2c-70f4291e0bef.invocation.api.nvcf.nvidia.com/v1/chat/completions
# Optional overrides (defaults shown)
# SARVAM_LLM_MODEL=sarvamai/sarvam-30b
# SARVAM_LLM_TEMPERATURE=0.8
# SARVAM_LLM_MAX_TOKENS=2048
# SARVAM_LLM_REPETITION_PENALTY=1.0
# SARVAM_LLM_TIMEOUT_SECONDS=60
