pipeline {
    agent any

    options {
        disableConcurrentBuilds()
    }

    parameters {
        string(name: 'BRANCH_NAME', defaultValue: 'develop', description: 'Enter branch to build')
    }

    environment {
        IMAGE_NAME = "voicera-frontend-prod"
        HARBOR_REGISTRY = "registryharbor.bhashini.co.in"
        HARBOR_REPO = "bhashini/voicera"
        IMAGE_TAG = "1.0.${BUILD_ID}"
    }

    stages {

        stage('Checkout') {
            steps {
                script {
                    withCredentials([usernamePassword(
                        credentialsId: 'github-creds',
                        usernameVariable: 'GIT_USERNAME',
                        passwordVariable: 'GIT_PASSWORD'
                    )]) {

                        checkout([$class: 'GitSCM',
                            branches: [[name: "*/${params.BRANCH_NAME}"]],
                            userRemoteConfigs: [[
                                url: 'https://github.com/bhashini-dibd/voicera_mono_repository.git',
                                credentialsId: 'github-creds'
                            ]]
                        ])

                        echo "Checked out branch ${params.BRANCH_NAME} for build #${BUILD_ID}"
                    }
                }
            }
        }

        stage('Build Image') {
            steps {
                sh """
                    cd voicera_frontend
                    podman build -t ${IMAGE_NAME}:${IMAGE_TAG} .
                    podman tag ${IMAGE_NAME}:${IMAGE_TAG} \
                    ${HARBOR_REGISTRY}/${HARBOR_REPO}/${IMAGE_NAME}:${IMAGE_TAG}
                """
            }
        }

        stage('Push Image') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-cred',
                    usernameVariable: 'Username',
                    passwordVariable: 'Password'
                )]) {
                    sh """
                        podman login ${HARBOR_REGISTRY} -u "$Username" -p "$Password"
                        podman push ${HARBOR_REGISTRY}/${HARBOR_REPO}/${IMAGE_NAME}:${IMAGE_TAG}
                    """
                }
            }
        }

        stage('Deploy to DEV Cluster') {
            steps {
                withKubeConfig([credentialsId: 'voicera-dev-cluster']) {
                    sh """
                        kubectl set image deployment/voicera-frontend \
                        voicera-frontend=${HARBOR_REGISTRY}/${HARBOR_REPO}/${IMAGE_NAME}:${IMAGE_TAG} \
                        -n voicera-frontend

                        kubectl rollout status deployment/voicera-frontend -n voicera-frontend
                    """
                }
            }
        }
    }

    post {
        always { cleanWs() }
    }
}
